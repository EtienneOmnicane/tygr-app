# ============================================================================
#  .env.prod.example — gabarit PRODUCTION Omni-FI (valeurs à renseigner localement)
# ----------------------------------------------------------------------------
#  Copier ce fichier vers `.env.prod` (ignoré par git) et le remplir, OU recopier
#  ces lignes dans votre `.env` actif pour cibler la PROD. Voir README.md
#  § « Démarrer en Sandbox vs Production » pour les commandes exactes.
#
#  Ce gabarit ne couvre QUE les variables qui DIFFÈRENT entre sandbox et prod.
#  Les variables communes (DATABASE_URL, AUTH_SECRET, …) restent celles de votre
#  `.env` habituel — voir `.env.example`.
# ============================================================================

# === Omni-FI Core API — PRODUCTION ===
# ⚠️ HÔTE PARTAGÉ sandbox↔production (constat 2026-06-26, confirmé tuteur). Omni-FI
# n'a PAS d'hôte de prod distinct : `api-stage.omni-fi.co` sert pour le sandbox ET la
# production. Ce qui fait la "vraie donnée", ce sont les CLÉS (prod) + l'EndUser, PAS
# l'hôte. On garde donc l'hôte stage ici. Pas de préfixe /v1 (routes à la racine), pas
# de slash final. (Le jour où Omni-FI ouvre un vrai hôte de prod, mettre son URL ici.)
OMNIFI_BASE_URL="https://api-stage.omni-fi.co"

# Bascule d'environnement. En prod : "production" — c'est l'INTENTION (on traite de la
# vraie donnée), pas une déduction de l'hôte. Sur un hôte partagé, la garde de cohérence
# env↔hôte n'impose rien ; c'est le drapeau ci-dessous qui autorise la prod (fail-closed).
OMNIFI_ENV="production"

# 🔓 DÉVERROUILLAGE DU VERROU PRODUCTION. Par défaut le code REFUSE OMNIFI_ENV="production"
# (verrou fail-closed, config.ts § verrouSandboxActif), QUEL QUE SOIT l'hôte — y compris
# l'hôte partagé. Mettre exactement "1" pour autoriser la prod (clés prod). Toute autre
# valeur (ou absence) = verrou actif. C'est l'opt-in volontaire qui assume la vraie donnée.
OMNIFI_AUTORISER_PRODUCTION="1"

# Identifiants de l'ApiClient de PRODUCTION (distincts de la sandbox). Le secret
# n'est affiché qu'une fois à la génération côté Omni-FI.
OMNIFI_CLIENT_ID=""
OMNIFI_SECRET=""

# ClientUserId de l'EndUser de production — requis sur tous les appels B2B.
# ⚠️ PIÈGE : le code lit le ClientUserId EN BASE (workspaces.omnifi_client_user_id,
# orchestration.ts), PAS cette variable. La renseigner ne suffit donc PAS. L'annuaire
# des EndUsers est rattaché aux CLÉS : un EndUser créé en sandbox est INCONNU des clés
# prod. Procédure : POST /clients/end-users avec les clés prod → écrire la valeur reçue
# dans la colonne du workspace (UPDATE). Voir docs/BASCULE-PRODUCTION-OMNIFI.md § piège 3.
OMNIFI_DEMO_CLIENT_USER_ID=""

# Environnement du WIDGET natif (variable CLIENT, AUCUN secret). Pilote le CDN du widget.
# ⚠️ Le CDN doit MATCHER l'API jointe : tant qu'on tape l'hôte staging (api-stage), garder
# "staging" → staging-cdn.omni-fi.co, MÊME en mode prod. Mettre "production" ici alors que
# l'API est staging charge le mauvais CDN → le widget peut ne jamais s'initialiser (piège 2).
NEXT_PUBLIC_OMNIFI_ENV="staging"

# Origines HTTPS autorisées pour le RedirectOrigin du widget (fail-closed si vide).
# En prod : l'origine HTTPS réelle de l'app, jamais http.
APP_ALLOWED_ORIGINS=""
