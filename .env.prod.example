# ============================================================================
#  .env.prod.example — gabarit PRODUCTION Omni-FI (valeurs à renseigner localement)
# ----------------------------------------------------------------------------
#  Copier ce fichier vers `.env.prod` (ignoré par git) et le remplir, OU recopier
#  ces lignes dans votre `.env` actif pour cibler la PROD. Voir README.md
#  § « Démarrer en Sandbox vs Production » pour les commandes exactes.
#
#  Ce gabarit ne couvre QUE les variables qui DIFFÈRENT entre sandbox et prod.
#  Les variables communes (DATABASE_URL, AUTH_SECRET, …) restent celles de votre
#  `.env` habituel — voir `.env.example`.
# ============================================================================

# === Omni-FI Core API — PRODUCTION ===
# Hôte REST de production (seul hôte de prod de l'allow-list, config.ts § HOTES_PRODUCTION).
# Pas de préfixe /v1 (routes à la racine), pas de slash final.
OMNIFI_BASE_URL="https://api.omni-fi.co"

# Bascule d'environnement. En prod : "production". La garde de cohérence env↔hôte
# (config.ts) EXIGE que cette valeur et OMNIFI_BASE_URL ci-dessus soient cohérentes
# (production ⇔ api.omni-fi.co), sinon le démarrage échoue (fail-closed).
OMNIFI_ENV="production"

# 🔓 DÉVERROUILLAGE DU VERROU SANDBOX. Par défaut le code REFUSE de démarrer en prod
# (verrou fail-closed, config.ts § verrouSandboxActif). Mettre exactement "1" pour
# autoriser OMNIFI_ENV="production" / l'hôte de prod. Toute autre valeur (ou absence)
# = verrou actif. C'est l'opt-in volontaire qui assume la cible production.
OMNIFI_AUTORISER_PRODUCTION="1"

# Identifiants de l'ApiClient de PRODUCTION (distincts de la sandbox). Le secret
# n'est affiché qu'une fois à la génération côté Omni-FI.
OMNIFI_CLIENT_ID=""
OMNIFI_SECRET=""

# ClientUserId de l'EndUser de production — requis sur tous les appels B2B.
OMNIFI_DEMO_CLIENT_USER_ID=""

# Environnement du WIDGET natif (variable CLIENT, AUCUN secret). En prod : "production"
# → CDN cdn.omni-fi.co (défaut du package). "staging" → staging-cdn.omni-fi.co.
NEXT_PUBLIC_OMNIFI_ENV="production"

# Origines HTTPS autorisées pour le RedirectOrigin du widget (fail-closed si vide).
# En prod : l'origine HTTPS réelle de l'app, jamais http.
APP_ALLOWED_ORIGINS=""
