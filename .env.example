# Connexion applicative — chaîne POOLÉE Neon (pooler en mode transaction),
# rôle tygr_app soumis à RLS. JAMAIS le rôle owner ici (CLAUDE.md règle 2).
DATABASE_URL="postgresql://tygr_app:<password>@<project>-pooler.<region>.aws.neon.tech/tygr?sslmode=require"

# Migrations uniquement (drizzle-kit) — rôle owner.
DATABASE_URL_ADMIN="postgresql://<owner>:<password>@<project>.<region>.aws.neon.tech/tygr?sslmode=require"

# Auth.js — signature/chiffrement du JWT de session. Générer : `openssl rand -base64 32`.
# Rotation : invalide toutes les sessions actives (runbook à compléter au déploiement).
AUTH_SECRET="<openssl rand -base64 32>"
# Hors Vercel (Docker derrière un proxy de confiance), décommenter :
# AUTH_TRUST_HOST="true"

# Seed du premier ADMIN (scripts/seed-admin.mjs) — UNIQUEMENT au provisioning
# initial, jamais en CI. Min 12 caractères ; à changer à la première connexion.
# SEED_ADMIN_PASSWORD="<mot de passe initial>"
