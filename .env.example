# Connexion applicative — chaîne POOLÉE Neon (pooler en mode transaction),
# rôle tygr_app soumis à RLS. JAMAIS le rôle owner ici (CLAUDE.md règle 2).
DATABASE_URL="postgresql://tygr_app:<password>@<project>-pooler.<region>.aws.neon.tech/tygr?sslmode=require"

# Migrations uniquement (drizzle-kit) — rôle owner.
DATABASE_URL_ADMIN="postgresql://<owner>:<password>@<project>.<region>.aws.neon.tech/tygr?sslmode=require"

# Auth.js — signature/chiffrement du JWT de session. Générer : `openssl rand -base64 32`.
# Rotation : invalide toutes les sessions actives (runbook à compléter au déploiement).
AUTH_SECRET="<openssl rand -base64 32>"
# Hors Vercel (Docker derrière un proxy de confiance), décommenter :
# AUTH_TRUST_HOST="true"

# Seed du premier ADMIN (scripts/seed-admin.mjs) — UNIQUEMENT au provisioning
# initial, jamais en CI. Min 12 caractères ; à changer à la première connexion.
# SEED_ADMIN_PASSWORD="<mot de passe initial>"

# === Omni-FI Core API (Stage/pré-prod pour la démo) ===
# Auth ApiKey serveur-à-serveur : "Authorization: ApiKey <client_id>:<secret>"
# (docs/documentation_api.md § Authentification). Le secret n'est affiché qu'une
# seule fois à la génération — JAMAIS commité ni mis en fixture (CLAUDE.md règle 8).
# Ces valeurs ne sont lues par aucun code avant la PR 1 (client Omni-FI) ; PR 0 ne
# fait que déclarer leur existence. Renseigner les vraies valeurs dans .env (ignoré).
# NOTE (2026-06-16, dump serveur Staging du tuteur) :
#  - L'hôte "sandbox.omni-fi.co" de la doc officielle est une coquille (NXDOMAIN).
#    Le vrai hôte de l'API de pré-prod est "api-stage.omni-fi.co" (/health/ → 200
#    vérifié). "stage.omni-fi.co" est le CDN du widget, PAS l'API REST.
#  - PAS de préfixe /v1 : la doc OpenAPI est fausse, les routes sont à la RACINE
#    (ex. /connections/link-token). Ne PAS remettre /v1 ici.
OMNIFI_BASE_URL="https://api-stage.omni-fi.co"
# 🔒 VERROU PRODUCTION (2026-06-22, MAJ 2026-06-26) : par défaut OMNIFI_ENV="production"
# est REFUSÉ (fail-closed, config.ts § verrouSandboxActif). Pour la sandbox, garder
# "sandbox" + un hôte sandbox/partagé (api-stage / stage). NB : api-stage est un hôte
# PARTAGÉ sandbox↔prod — l'environnement se décide par les CLÉS + le drapeau
# OMNIFI_AUTORISER_PRODUCTION, pas par l'hôte. Passage prod = .env.prod.example (poser
# le drapeau à "1" + clés prod), jamais en touchant cette config sandbox.
OMNIFI_ENV="sandbox"
OMNIFI_CLIENT_ID="<client_id Omni-FI, ex: client_3f9f4a5e2c0d4b8a>"
OMNIFI_SECRET="<secret généré via POST /clients/{ApiClientId}/keys/generate>"
# clientUserId de l'EndUser sandbox pré-connecté — requis sur tous les appels B2B
# (docs/documentation_api.md § Architecture multi-tenant).
OMNIFI_DEMO_CLIENT_USER_ID="<ClientUserId de l'utilisateur sandbox>"

# Environnement du WIDGET natif (@omni-fi/react-link). Variable CLIENT (préfixe
# NEXT_PUBLIC_) lue par le launcher côté navigateur — AUCUN secret. Pilote le CDN du
# widget : "staging" → staging-cdn.omni-fi.co (sandbox de démo) ; "production" (défaut
# du package) → cdn.omni-fi.co. Pour la démo sandbox, mettre "staging".
NEXT_PUBLIC_OMNIFI_ENV="staging"

# Allowlist serveur des origines autorisées pour le RedirectOrigin du widget
# (constat cross-review PR-W4 3.1). Liste séparée par virgules. FAIL-CLOSED : si
# vide, aucune connexion widget n'est autorisée. En PROD/démo : l'origine HTTPS
# réelle, ex. APP_ALLOWED_ORIGINS="https://app.tygr.mu" (JAMAIS http en prod).
APP_ALLOWED_ORIGINS="https://app.tygr.mu"

# DEV LOCAL UNIQUEMENT — opt-in explicite pour tester le démarrage du widget en
# http://localhost (le RedirectOrigin du navigateur est http en dev). À "1" SEULEMENT
# en dev : ignoré si NODE_ENV=production (audit sécurité C1 — fail-closed). Si activé,
# ajouter aussi l'origine localhost à APP_ALLOWED_ORIGINS ci-dessus. NE JAMAIS déployer.
#   APP_ALLOW_INSECURE_LOCALHOST="1"
#   APP_ALLOWED_ORIGINS="http://localhost:3000"

# === Inngest (jobs durables — lot W1, PLAN-ingestion-webhook-omnifi.md §6/§7) ===
# Les deux clés sont lues NATIVEMENT par le SDK ; env vars uniquement, jamais en
# fixture ni loggées (règle 8). Distinctes par environnement déployé.
#  - INNGEST_SIGNING_KEY : authentifie les appels du serveur Inngest vers
#    /api/inngest (signature vérifiée par `serve` — fail-closed en mode cloud :
#    sans elle, la route refuse de servir). REQUISE en staging/production.
#  - INNGEST_EVENT_KEY : autorise l'émission d'événements (`inngest.send`).
#    REQUISE en staging/production.
# DEV LOCAL : laisser les deux ABSENTES et lancer le dev server Inngest à côté de
# `npm run dev` : `npx inngest-cli@latest dev` (dashboard http://localhost:8288 —
# exécution des fonctions, déclenchement manuel, healthcheck). Sans dev server,
# l'émission échoue proprement (fail-soft journalisé) : le bouton « Synchroniser »
# garde son comportement synchrone, l'invite à relancer réapparaît.
# INNGEST_SIGNING_KEY="signkey-…"
# INNGEST_EVENT_KEY="…"
