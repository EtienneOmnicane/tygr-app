{
  "name": "@omni-fi/react-link",
  "version": "0.1.0",
  "description": "Official React SDK for OmniFI Link",
  "license": "MIT",
  "author": "Omni-FI <admin@omni-fi.co> (https://omni-fi.co)",
  "homepage": "https://github.com/omni-fi-app/omni-fi-react-link#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/omni-fi-app/omni-fi-react-link.git"
  },
  "bugs": {
    "url": "https://github.com/omni-fi-app/omni-fi-react-link/issues"
  },
  "keywords": [
    "omni-fi",
    "open-banking",
    "fintech",
    "bank-connection",
    "account-aggregation",
    "react",
    "react-hook",
    "sdk",
    "africa",
    "mauritius"
  ],
  "packageManager": "bun@1.3.14",
  "main": "dist/index.cjs",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md",
    "CHANGELOG.md"
  ],
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/",
    "provenance": true
  },
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts --clean",
    "dev": "tsup src/index.ts --format cjs,esm --dts --watch",
    "lint": "eslint .",
    "test": "bun test"
  },
  "devDependencies": {
    "@happy-dom/global-registrator": "^20.9.0",
    "@testing-library/react": "^16.3.2",
    "@types/bun": "latest",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "eslint": "^9.0.0",
    "eslint-plugin-react-hooks": "^5.0.0",
    "happy-dom": "^20.9.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tsup": "^8.5.1",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.0.0"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0"
  }
}
